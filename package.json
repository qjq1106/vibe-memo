{
  "name": "vibe-memo",
  "version": "2.0.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev",
    "dev:electron": "tsc -p electron/tsconfig.json && concurrently -k \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build:electron": "tsc -p electron/tsconfig.json && next build && electron-builder",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "node node_modules/prisma/build/index.js generate",
    "db:migrate": "node node_modules/prisma/build/index.js migrate dev",
    "db:status": "node node_modules/prisma/build/index.js migrate status"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.10.0",
    "next": "16.2.9",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "yet-another-react-lightbox": "^3.32.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.0.0",
    "dotenv": "^17.2.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-updater": "^6.3.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^8.0.5"
  }
}
